# Database (Neon)
TWILIO_SERVICE_DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Twilio Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio Phone Numbers (one per project)
TWILIO_MCPFACTORY_PHONE_NUMBER=+15551234567
TWILIO_PRESSBEAT_PHONE_NUMBER=+15559876543

# Authentication (service-to-service)
TWILIO_SERVICE_API_KEY=shared-secret-for-service-to-service-auth

# Runs Service (run tracking & cost management)
RUNS_SERVICE_URL=http://localhost:3006
RUNS_SERVICE_API_KEY=your-runs-service-api-key

# Server
PORT=3011
